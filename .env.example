DATABASE_URL="postgresql://postgres:postgres@localhost:5432/physio_booking?schema=public"
PORT=3000
JWT_SECRET="replace-with-a-strong-secret"

# CORS: comma-separated frontend origins. Required when NODE_ENV=production.
# Local dev: leave unset to allow all origins.
# Railway: set at least one of these on the backend service:
# CORS_ORIGINS="https://crack-fe-febrianrachmat-production.up.railway.app"
# FRONTEND_URL="https://crack-fe-febrianrachmat-production.up.railway.app"

# Rate limiting: global ~120 req/min/IP (auth login/register ~15/min). Integration tests set DISABLE_THROTTLE=true in setup.
# DISABLE_THROTTLE=true

# Phase 3: auto-refund if therapist sends no chat message after payment (optional overrides).
# CONSULTATION_SLA_CRON=false
# CONSULTATION_SLA_FAST_MINUTES=10
# CONSULTATION_SLA_STANDARD_MINUTES=1440

# H-1 visit reminders (in-app + email mock). Cron hourly; disable in tests with APPOINTMENT_REMINDER_CRON=false.
# APPOINTMENT_REMINDER_CRON=false
# APPOINTMENT_REMINDER_HOURS_BEFORE=24
# APPOINTMENT_REMINDER_WINDOW_MINUTES=60

# Docker/Railway: set RUN_DB_SEED=true for one deploy to load prisma/seed.ts demo users, then remove or set false.
# RUN_DB_SEED=true
# SEED_DEFAULT_PASSWORD="password123"

# OAuth (optional). FRONTEND_URL required for OAuth redirects (same as CORS frontend).
# API_PUBLIC_URL="https://crack-be-febrianrachmat-production.up.railway.app"
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# APPLE_CLIENT_ID=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Chat SSE poll interval (ms) for GET .../messages/stream (default 2500, clamped 1s–15s).
# CHAT_SSE_POLL_MS=2500

# Notification email mock (logs to server console; default on except production)
# EMAIL_MOCK_ENABLED=true
