DATABASE_URL="postgresql://postgres:postgres@localhost:5432/physio_booking?schema=public"
PORT=3000
JWT_SECRET="replace-with-a-strong-secret"

# CORS: comma-separated frontend origins. Required when NODE_ENV=production.
# Local dev: leave unset to allow all origins.
# CORS_ORIGINS="http://localhost:3000,https://your-frontend.up.railway.app"

# Rate limiting: global ~120 req/min/IP (auth login/register ~15/min). Integration tests set DISABLE_THROTTLE=true in setup.
# DISABLE_THROTTLE=true

# Phase 3: auto-refund if therapist sends no chat message after payment (optional overrides).
# CONSULTATION_SLA_CRON=false
# CONSULTATION_SLA_FAST_MINUTES=10
# CONSULTATION_SLA_STANDARD_MINUTES=1440

# Docker/Railway: set RUN_DB_SEED=true for one deploy to load prisma/seed.ts demo users, then remove or set false.
# RUN_DB_SEED=true
# SEED_DEFAULT_PASSWORD="password123"
